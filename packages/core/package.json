{
  "name": "@erode-app/core",
  "version": "0.0.1",
  "description": "Architecture erosion detection",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "erode-ci": "./dist/ci-entry.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/**/__tests__"
  ],
  "scripts": {
    "check:ci": "concurrently --group \"npm:lint\" \"npm:typecheck\" \"npm:format:check\" \"npm:check:schema\"",
    "check:schema": "tsx scripts/generate-schema.ts --check",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "bash scripts/copy-assets.sh",
    "dev": "tsx watch src/ci-entry.ts",
    "start": "node dist/ci-entry.js",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate:schema": "tsx scripts/generate-schema.ts"
  },
  "keywords": [
    "architecture",
    "erode",
    "c4-model"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/erode-app/erode.git",
    "directory": "packages/core"
  },
  "author": "Anders Hassis",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@gitbeaker/rest": "^43.8.0",
    "@google/genai": "^1.50.0",
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.4.1",
    "likec4": "^1.54.0",
    "minimatch": "^10.2.5",
    "openai": "^6.34.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@erode-app/eslint-config": "*",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "prettier": "^3.7.3",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
