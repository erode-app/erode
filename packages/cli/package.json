{
  "name": "@erode-app/cli",
  "version": "0.0.1",
  "description": "Interactive CLI for erode architecture drift detection",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "erode": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:ci": "concurrently --group \"npm:lint\" \"npm:typecheck\" \"npm:format:check\" \"npm:build\""
  },
  "license": "MIT",
  "dependencies": {
    "@erode-app/core": "*",
    "chalk": "^5.3.0",
    "commander": "^14.0.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@erode/eslint-config": "*",
    "@types/node": "^24.11.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "prettier": "^3.7.3",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
